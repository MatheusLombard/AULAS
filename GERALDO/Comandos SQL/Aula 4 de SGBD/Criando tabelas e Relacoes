CREATE TABLE tb_clientes(
    rg_cliente        VARCHAR(15),
    nm_cliente      VARCHAR(60),
    dt_nascimento   DATE,
    CONSTRAINT pk_tb_clientes_rg_cliente PRIMARY KEY(rg_cliente)
)

CREATE TABLE tb_bibliotecarias(
    rg_bibliotecaria    VARCHAR(15),
    nm_bibliotecaria    VARCHAR(60),
    dt_nascimento       DATE,
    CONSTRAINT pk_tb_bibliotecaria_rg_bibliotecaria PRIMARY KEY(rg_bibliotecaria)
)

CREATE TABLE tb_livros(
    codigo              INTEGER,
    ds_livro            INTEGER,
    rg_cliente          VARCHAR(15),
    dt_devolucao        DATE,
    rg_bibliotecaria    VARCHAR(15),
    CONSTRAINT pk_tb_livros_codigo PRIMARY KEY(codigo),
    CONSTRAINT fk_tb_livros_rg_cliente FOREIGN KEY(rg_cliente)
        REFERENCES tb_clientes(rg_cliente),
    CONSTRAINT fk_tb_livros_rg_bibliotecaria FOREIGN KEY(rg_bibliotecaria) 
        REFERENCES tb_bibliotecarias(rg_bibliotecaria)
)

CREATE TABLE tb_clientes(
    rg  VARCHAR(15),
    nm_cliente VARCHAR(60),
    dt_nasc DATE,
    CONSTRAINT pk_tb_clientes_rg PRIMARY KEY(rg)
)

CREATE TABLE tb_contas(
    nr INTEGER,
    ds_conta  VARCHAR(20),
    dt_abertura DATE,
    CONSTRAINT pk_tb_contas_nr PRIMARY KEY(nr)
)

CREATE TABLE tb_correntistas(
    rg      VARCHAR(15),
    nr_conta    INTEGER,
    CONSTRAINT pk_tb_correntistas_rg_nr PRIMARY KEY (rg, nr_conta),
    CONSTRAINT fk_tb_correntistas_rg FOREIGN KEY(rg) REFERENCES tb_clientes(rg),
    CONSTRAINT fk_tb_correntistas_nr_conta FOREIGN KEY(nr_conta) REFERENCES tb_contas(nr)
)

CREATE TABLE tb_cartoes(
    nr INTEGER,
    dt_expedicao DATE,
    rg   VARCHAR(15) CONSTRAINT nn_tb_cartoes_rg NOT NULL,
    nr_conta INTEGER CONSTRAINT nn_tb_cartoes_nr_conta NOT NULL,
    CONSTRAINT pk_tb_cartoes_nr PRIMARY KEY(nr),
    CONSTRAINT fk_tb_cartoes_rg FOREIGN KEY(rg) REFERENCES tb_clientes(rg)
    CONSTRAINT fk_tb_cartoes_nr_conta FOREIGN KEY(nr_conta) REFERENCES tb_contas(nr)
)