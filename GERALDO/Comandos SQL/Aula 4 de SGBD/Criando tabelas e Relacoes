CREATE TABLE tb_empregados(
    rg VARCHAR(15),
    nm_empregado VARCHAR(40),
    CONSTRAINT pk_tb_empregados_codigo PRIMARY KEY(rg)
)

CREATE TABLE tb_projetos(
    codigo INTEGER,
    ds_projeto VARCHAR(40),
    CONSTRAINT pk_tb_projetos_codigo PRIMARY KEY(codigo)
)

CREATE TABLE tb_participacoes(
    rg VARCHAR(15),
    codigo INTEGER, 
    dt_inicio DATE,
    CONSTRAINT pk_tb_participacoes_rg PRIMARY KEY(rg, codigo),
    CONSTRAINT fk_tb_participacoes_rg FOREIGN KEY(rg)
        REFERENCES tb_empregados(rg),
    CONSTRAINT fk_tb_participacoes_cod FOREIGN KEY(codigo)
        REFERENCES tb_projetos(codigo)
)
DROP TABLE tb_empregados CASCADE;

CREATE TABLE tb_empregados(
    rg              VARCHAR(15),
    nm_empregados   VARCHAR(60),
    dt_nasciment   DATE,
    rg_gerente      VARCHAR(15),
    CONSTRAINT pk_tb_empregados_rg PRIMARY KEY(rg),
    CONSTRAINT fk_tb_empregados_rg_gerente FOREIGN KEY(rg_gerente) 
        REFERENCES tb_empregados(rg)
)

